# ====================================================
# HHI Luxury Guide - Environment Variables
# ====================================================
# Copy this file to .env.local and fill in your values.
# Lines starting with # are comments.
# ====================================================

# ── REQUIRED: Convex Database ──────────────────────
# Create a free account at https://convex.dev, then run `npx convex dev`
# to get these values automatically written to .env.local

VITE_CONVEX_URL=https://your-deployment.convex.cloud
CONVEX_DEPLOYMENT=dev:your-deployment-name

# ── REQUIRED: Auth Keys ────────────────────────────
# Generate an RSA keypair for auth token signing:
#   openssl genrsa 2048 > private.pem
#   openssl rsa -in private.pem -pubout > public.pem
# Then paste the private key below (keep the BEGIN/END lines)

JWT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END PRIVATE KEY-----

# JWKS is the public key in JWK Set format (JSON).
# Generate from your public key at https://russelldavies.github.io/jwk-creator/
JWKS={"keys":[{"kty":"RSA","n":"YOUR_MODULUS","e":"AQAB"}]}

# ── REQUIRED: Site URL ─────────────────────────────
# Your production domain (used for auth redirects and meta tags)
SITE_URL=https://hiltonheaddirectory.com

# ── OPTIONAL: Convex HTTP Actions URL ──────────────
# Usually auto-derived from VITE_CONVEX_URL. Only set if custom.
# VITE_CONVEX_SITE_URL=https://your-deployment.convex.site

# ── OPTIONAL: Preview Mode ─────────────────────────
# Set to "true" on preview/staging builds to show test-user login
# VITE_IS_PREVIEW=true

# ── OPTIONAL: CI/CD Deploy Key ─────────────────────
# Only needed for automated deployments (GitHub Actions, etc.)
# Get from Convex dashboard > Project Settings > Deploy Keys
# CONVEX_DEPLOY_KEY=prod:your-deploy-key

# ── VIKTOR PLATFORM (remove for self-hosting) ─────
# These connect to the Viktor hosting platform.
# For fully independent hosting, delete these and remove
# references to viktorTools.ts in the Convex backend.
# VIKTOR_SPACES_API_URL=https://...
# VIKTOR_SPACES_PROJECT_NAME=hhi-luxury-guide
# VIKTOR_SPACES_PROJECT_SECRET=your-secret
# VIKTOR_SPACES_IS_PREVIEW=false
